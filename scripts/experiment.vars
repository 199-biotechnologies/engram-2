# engram autoresearch experiment knobs — LoCoMo-QA loop
# Target file for autoresearch. Each experiment tweaks ONE value here.
# The eval script sources this before running the bench.
#
# All values have sensible defaults in the binary; unset to use default.

# Reranker: cohere | zerank2 | passthrough
ENGRAM_RERANK_PROVIDER=cohere

# Gemini embedding model: gemini-embedding-001 | gemini-embedding-2-preview
GEMINI_EMBED_MODEL=gemini-embedding-001

# MLX zerank-2 sidecar URL (only used when ENGRAM_RERANK_PROVIDER=zerank2)
ENGRAM_ZERANK_URL=http://127.0.0.1:8766

# Bench slice size (deterministic first-N questions)
ENGRAM_LOCOMO_LIMIT=50

# Top-k chunks passed to answerer
ENGRAM_LOCOMO_TOPK=5

# Answerer / judge models (kept stable across experiments unless noted)
ENGRAM_ANSWERER=openai/gpt-5.4
ENGRAM_JUDGE=openai/gpt-5.4
